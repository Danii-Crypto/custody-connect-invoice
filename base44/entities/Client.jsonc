{
  "name": "Client",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Vessel owner or company name"
    },
    "email": {
      "type": "string",
      "description": "Owner email address"
    },
    "vessel_name": {
      "type": "string",
      "description": "Name of the vessel/boat"
    },
    "addr1": {
      "type": "string",
      "description": "Address line 1"
    },
    "addr2": {
      "type": "string",
      "description": "Address line 2"
    },
    "country": {
      "type": "string",
      "description": "Country code or name"
    },
    "notes": {
      "type": "string",
      "description": "Optional notes about the client"
    }
  },
  "required": [
    "name"
  ]
}